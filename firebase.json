{
  "hosting": [
    {
      "target": "archive-marathon",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "run": {
            "serviceId": "ms-inv-prod",
            "region": "us-central1"
          }
        }
      ]
    }
  ]
}
